<style>
  :root {
    --color-accent: #D94881; /* Fundo do Footer */
    --color-text: #F9F2EC;   /* Cor do texto */
    --color-whatsapp: #47C243; /* Fundo do botão do Whats */
    --color-whatsapp-hover: #30A32C; /* Hover do Whats */
    --font-primary: 'DM Serif Text', serif;
  }

  /* Reset local apenas para o footer */
  .site-footer * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* Footer Section */
  .site-footer {
    background-color: var(--color-accent);
    padding: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 99;
    position: relative;
    width: 100%;
  }

  .footer-container {
    width: 100%;
    max-width: 1140px;
  }

  /* Links Flex Container */
  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 60px;
    list-style: none;
  }

  .footer-links li {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .footer-links a:hover {
    opacity: 0.8;
  }

  .footer-links .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 14px; /* Aumentei levemente para melhor leitura */
    height: 14px;
  }

  /* Ajuste para garantir que todos SVG's fiquem proporcionais */
  .footer-links .icon svg {
    width: 100%;
    height: auto;
    max-height: 14px;
  }

  .footer-links .text {
    font-family: var(--font-primary);
    font-size: 16px;
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: 0.3px;
    line-height: 1.2;
  }

  /* Botão Flutuante do WhatsApp */
  .floating-whatsapp {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background-color: var(--color-whatsapp);
    color: #FFFFFF;
    border-radius: 100px;
    padding: 11px 13px 9px 13px;
    box-shadow: 0px 0px 10px 0px var(--color-whatsapp);
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease, transform 0.2s ease;
    text-decoration: none;
  }

  .floating-whatsapp:hover,
  .floating-whatsapp:focus {
    background-color: var(--color-whatsapp-hover);
    transform: scale(1.05);
  }

  .floating-whatsapp .btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .floating-whatsapp svg {
    width: 45px;
    height: 45px;
    fill: #FFFFFF;
  }

  /* Responsividade */
  @media (max-width: 1024px) {
    .footer-links {
      flex-direction: column;
      gap: 15px;
      text-align: center;
    }

    .footer-links li, .footer-links a {
      justify-content: center;
    }

    /* Ajuste no tamanho do ícone do Whats mobile */
    .floating-whatsapp svg {
      width: 35px;
      height: 35px;
    }
    
    .floating-whatsapp {
      padding: 9px 11px 7px 11px;
    }

    .footer-links .text {
      font-size: 14px;
    }

  }
</style>