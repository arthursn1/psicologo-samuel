---
// FAQ.astro

const faqs = [
  {
    question: "Como funciona a terapia online?",
    answer: "A terapia online segue os mesmos princípios éticos e técnicos da terapia presencial, com a diferença de que os encontros acontecem por videochamada. As sessões são semanais, com tempo médio de 50 minutos e máximo de 55 minutos. A terapia online é tão eficaz quanto a presencial.",
    open: true
  },
  {
    question: "Quando vou perceber os resultados?",
    answer: "O tempo para perceber resultados na psicoterapia varia, dependendo dos objetivos e da natureza e particularidade de cada dificuldade. Algumas mudanças podem ser percebidas em poucas semanas, enquanto outras exigem mais tempo e dedicação. O foco está em construir avanços significativos e sustentáveis, sempre respeitando o seu ritmo e as suas necessidades."
  },
  {
    question: "As sessões são realmente confidenciais?",
    answer: "Todas as sessões são realizadas em sigilo, conforme o Código de Ética Profissional do Psicólogo – Art. 9o. Você pode se sentir seguro e a vontade para compartilhar qualquer questão que quiser, tendo a certeza de que te escutarei com respeito, empatia e sem julgamentos."
  },
  {
    question: "Quais cuidados devo ter ao escolher um psicólogo?",
    answer: "Avalie se o terapeuta possui Carteira de Registro Profissional e Cadastro no Conselho Regional e Federal de Psicologia. Cheque se o profissional tem uma formação continuada e acadêmica adequadas. Sua saúde mental é muito importante, procure um profissional que invista na qualificação."
  },
  {
    question: "Quais são os valores e meios de pagamento?",
    answer: "Para saber os valores das sessões basta entrar em contato comigo pelo WhatsApp. Os pagamentos são realizados antes das sessões e você poderá utilizar Pix ou transferência bancária."
  },
  {
    question: "Trabalha com plano de saúde ou convênio?",
    answer: "Embora não trabalhe diretamente com planos de saúde, emito recibos que podem ser utilizados para solicitar reembolso, dependendo da sua cobertura. Nesses casos, o recomendado é que você entre em contato com seu plano para confirmar as condições."
  }
];
---

<section class="faq-section">
  <div class="container">
    
    <div class="faq-header">
      <h2 class="title">
        <span class="destaque">FAQ</span> - Perguntas Frequentes
      </h2>
    </div>

    <div class="faq-accordion">
      {faqs.map((faq) => (
        <details class="faq-item" name="faq-group" open={faq.open}>
          <summary class="faq-summary">
            <h3 class="faq-question">{faq.question}</h3>
            <span class="faq-icon">
              <svg aria-hidden="true" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
                <path d="M504 256c0 137-111 248-248 248S8 393 8 256 119 8 256 8s248 111 248 248zM273 369.9l135.5-135.5c9.4-9.4 9.4-24.6 0-33.9l-17-17c-9.4-9.4-24.6-9.4-33.9 0L256 285.1 154.4 183.5c-9.4-9.4-24.6-9.4-33.9 0l-17 17c-9.4 9.4-9.4 24.6 0 33.9L239 369.9c9.4 9.4 24.6 9.4 34 0z"></path>
              </svg>
            </span>
          </summary>
          <div class="faq-content">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="faq-footer">
      <h2 class="footer-title">
        <span class="dest2">Ainda tem dúvidas?</span>
      </h2>
      <a href="https://wa.me/5537998164092?text=Ol%C3%A1,%20vim%20do%20site%20e%20gostaria%20de%20agendar%20uma%20consulta!" class="whatsapp-button" target="_blank" rel="noopener noreferrer">
        <span class="btn-text">Me chame no WhatsApp</span>
        <span class="btn-icon">
          <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
            <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"></path>
          </svg>
        </span>
        
      </a>
    </div>
  </div>
</section>

<style>
  :root {
    --color-primary: #0B4491;
    --color-accent: #D94881;
    --color-accordion-bg: #0A3C80;
    --color-text-light: #F9F2EC;
    --color-text-content: #E2E8FC;
    --font-heading: 'DM Serif Text', serif;
    --font-body: 'Open Sans', sans-serif;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .faq-section {
    background-color: var(--color-primary);
    padding: 60px 20px 100px;
    color: var(--color-text-light);
    display: flex;
    justify-content: center;
  }

  .container {
    width: 100%;
    max-width: 1140px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .faq-header {
    text-align: center;
    padding: 50px 50px 80px 50px;
    background-image: url('../../assets/Vector-2-2.png');
    background-position: center center;
    background-repeat: no-repeat;
    background-size: contain;
  }

  .title {
    font-family: var(--font-heading);
    font-size: 70px;
    font-weight: 400;
    line-height: 1.1em;
    color: var(--color-text-light);
  }

  .destaque {
    background-image: url('../../assets/Vector-1-1-1.svg');
    background-position: center;
    background-size: contain;
    background-repeat: no-repeat;
    padding: 10px 30px;
    font-style: normal;
  }

  /* Accordion */
  .faq-accordion {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .faq-item {
    background-color: var(--color-accordion-bg);
    border: 1px solid rgba(149, 192, 208, 0.26);
    transition: background-color 0.3s ease;
  }

  .faq-item:hover, .faq-item[open] {
    background-color: var(--color-accent);
  }

  .faq-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 25px 20px;
    cursor: pointer;
    list-style: none; 
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-question {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.3px;
    color: var(--color-text-light);
  }

  .faq-icon svg {
    width: 20px;
    height: 20px;
    fill: var(--color-text-light);
    transition: transform 0.3s ease;
  }

  .faq-item[open] .faq-icon svg {
    transform: rotate(180deg);
  }

  .faq-content {
    background-color: var(--color-accent);
    border-top: 20px solid var(--color-primary);
    padding: 20px 25px 20px;
  }

  .faq-content p {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5em;
    color: var(--color-text-content);
  }

  /* Rodapé / Chamada para Ação */
  .faq-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    margin-top: 60px;
    gap: 20px;
  }

  .footer-title {
    font-family: var(--font-heading);
    font-size: 70px;
    font-weight: 400;
    color: var(--color-text-light);
  }

  /* Destaque "Ainda tem dúvidas?" */
  .dest2 {
    background: #105FCB;
    padding: 0px 8px;
    position: relative;
    z-index: 2;
    display: inline-block;
    border-left: 1px solid #95C0D0;
    border-right: 1px solid #95C0D0;
    font-style: italic;
  }

  .dest2::before, .dest2::after {
    position: absolute;
    content: "";
    background: #95C0D0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    z-index: 2;
  }

  .dest2::before {
    top: -3px;
    left: -4px;
  }

  .dest2::after {
    bottom: -3px;
    right: -4px;
  }

  /* Botão do WhatsApp */
  .whatsapp-button {
    display: flex;
    align-items: center;
    gap: 15px;
    background-color: transparent; /* Removido background para evitar hover retangular */
    background-image: url('../../assets/bg-botao.webp');
    background-size: contain; /* Ajusta a imagem no formato original sem esticar */
    background-repeat: no-repeat;
    background-position: center;
    color: var(--color-text-light);
    text-decoration: none;
    padding: 31px 40px 32px 85px; /* Restaurado o padding original do Elementor */
    transition: filter 0.3s ease;
  }

  .whatsapp-button:hover {
    filter: brightness(1.2);
  }

  .btn-icon svg {
    width: 25px;
    height: 25px;
    fill: var(--color-text-light);
  }

  .btn-text {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
  }

  /* Responsivo para Tablet e Mobile */
  @media (max-width: 1024px) {
    .title, .footer-title {
      font-size: 45px;
    }
    
    .faq-header {
      padding: 0 30px 15px;
      background-position: bottom center;
    }

    .destaque {
      background-size: cover;
      padding: 5px 15px;
    }
    
    .faq-summary {
      padding: 13px 20px 15px;
    }
    
    .faq-question {
      font-size: 1.1em;
    }

    .faq-footer {
      justify-content: center;
      text-align: center;
      margin-top: 20px;
    }
    
    .whatsapp-button {
      width: 100%;
      max-width: 300px;
      justify-content: center;
      padding: 25px 10px 28px 40px; /* Alinhamento especial mobile */
    }
  }

  @media (max-width: 767px) {
    .faq-section {
      padding: 70px 20px 70px;
    }

    .faq-header {
      text-align: center;
      padding: 20px 0px 30px 0px;
      background-image: url('../../assets/Vector-2-2.png');
      background-position: right;
      background-repeat: no-repeat;
      background-size: contain;
    }

    .title {
      font-size: 24px;
      padding: 0;
    }

    .title br {
      display: none;
    }

    .footer-title {
      font-size: 24px;
    }

    .faq-question {
      font-size: 15px;
      line-height: 1.3em;
    }

    .faq-content {
      padding: 20px 20px;
    }

    .faq-content p {
      font-size: 14px;
    }

    .btn-text {
      font-size: 16px;
      margin: 0 -6px 0 0;
      padding: 0 0 0 10px;
    }

    .btn-icon svg {
      width: 20px;
      height: 20px;
    }

  }
</style>