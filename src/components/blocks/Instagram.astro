---
// src/components/Instagram.astro
import { Image } from 'astro:assets'; 
import Slide1 from '../../assets/1-819x1024.jpg';
import Slide2 from '../../assets/2-819x1024.jpg';
import Slide3 from '../../assets/3-819x1024.jpg';
import Slide4 from '../../assets/4-819x1024.jpg';
import Slide5 from '../../assets/5-819x1024.jpg';
import Slide6 from '../../assets/6-819x1024.jpg';

const posts = [
  {
    img: Slide1,
    link: "https://www.instagram.com/p/DQuYpPDgcws/?img_index=1",
    alt: "Post Instagram 1"
  },
  {
    img: Slide2,
    link: "https://www.instagram.com/p/DQULJScDTeG/?img_index=1",
    alt: "Post Instagram 2"
  },
  {
    img: Slide3,
    link: "https://www.instagram.com/p/DReg584DcmZ/?img_index=1",
    alt: "Post Instagram 3"
  },
  {
    img: Slide4,
    link: "https://www.instagram.com/p/DS2lBIBjUNT/?img_index=1",
    alt: "Post Instagram 4"
  },
  {
    img: Slide5,
    link: "https://www.instagram.com/p/DSBNiusDf3O/?img_index=1",
    alt: "Post Instagram 5"
  },
  {
    img: Slide6,
    link: "https://www.instagram.com/p/DP8yIo2DXf3/?img_index=1",
    alt: "Post Instagram 6"
  }
];
---

<section class="instagram-section">
  <div class="container">
    
    <header class="section-header">
      <h2>Conteúdos de saúde mental no meu Instagram</h2>
      <p>Conheça um pouco mais sobre mim e do meu trabalho como psicólogo no meu Instagram</p>
    </header>

    <div class="carousel-wrapper" id="instagram-carousel">
      
      <button class="carousel-arrow prev" aria-label="Slide anterior">
        <svg aria-hidden="true" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
          <path d="M256 504C119 504 8 393 8 256S119 8 256 8s248 111 248 248-111 248-248 248zM142.1 273l135.5 135.5c9.4 9.4 24.6 9.4 33.9 0l17-17c9.4-9.4 9.4-24.6 0-33.9L226.9 256l101.6-101.6c9.4-9.4 9.4-24.6 0-33.9l-17-17c-9.4-9.4-24.6-9.4-33.9 0L142.1 239c-9.4 9.4-9.4 24.6 0 34z"></path>
        </svg>
      </button>

      <div class="carousel-track">
        {posts.map((post) => (
          <a href={post.link} target="_blank" rel="noopener noreferrer" class="carousel-slide" aria-label="Ver post no Instagram">
            <figure class="slide-inner">
              <Image src={post.img} alt={post.alt} width="819" height="1024" loading="lazy" decoding="async" />
              
              <div class="slide-overlay">
                <svg class="overlay-icon" aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
                  <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path>
                </svg>
              </div>
              
            </figure>
          </a>
        ))}
      </div>

      <button class="carousel-arrow next" aria-label="Próximo slide">
        <svg aria-hidden="true" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
          <path d="M256 8c137 0 248 111 248 248S393 504 256 504 8 393 8 256 119 8 256 8zm113.9 231L234.4 103.5c-9.4-9.4-24.6-9.4-33.9 0l-17 17c-9.4 9.4-9.4 24.6 0 33.9L285.1 256 183.5 357.6c-9.4 9.4-9.4 24.6 0 33.9l17 17c9.4 9.4 24.6 9.4 33.9 0L369.9 273c9.4-9.4 9.4-24.6 0-34z"></path>
        </svg>
      </button>

    </div>

    <div class="carousel-pagination">
      {posts.map((_, index) => (
        <button 
          class={`dot ${index === 0 ? 'active' : ''}`} 
          data-target={index} 
          aria-label={`Ir para a página ${index + 1}`}>
        </button>
      ))}
    </div>

    <div class="action-buttons">
      <a href="https://wa.me/5537998164092?text=Ol%C3%A1,%20vim%20do%20site%20e%20gostaria%20de%20agendar%20uma%20consulta!" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp">
        <span class="btn-content">
          <span>Agendar Minha Consulta</span>
          <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
            <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"></path>
          </svg>
        </span>
      </a>

      <a href="https://www.instagram.com/psi.samuelalcantara/" target="_blank" rel="noopener noreferrer" class="btn btn-instagram">
        <span class="btn-content">
          <svg aria-hidden="true" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
            <path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"></path>
          </svg>
          <span>psi.samuelalcantara</span>
        </span>
      </a>
    </div>

  </div>
</section>

<style>
  /* --- Seção e Container --- */
  .instagram-section {
    padding: 80px 20px;
    background-color: #FFFFFF;
    overflow: hidden;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
  }

  /* --- Cabeçalho --- */
  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-header h2 {
    font-family: "DM Serif Text", serif;
    font-size: 46px;
    font-weight: 500;
    color: #0B4491;
    margin: 0 0 10px 0;
    line-height: 1.2em;
  }

  .section-header p {
    font-family: "Open Sans", sans-serif;
    font-size: 18px;
    font-weight: 500;
    color: #0B4491;
    margin: 0;
    line-height: 1.2em;
  }

  /* --- Carrossel CSS --- */
  .carousel-wrapper {
    position: relative;
    width: 100%;
    margin-bottom: 20px; /* Reduzido levemente para dar espaço aos dots */
  }

  .carousel-track {
    display: flex;
    gap: 30px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding-bottom: 20px;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-slide {
    flex: 0 0 calc(33.333% - 20px);
    scroll-snap-align: start;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .carousel-slide:hover {
    transform: translateY(-5px);
  }

  .slide-inner {
    margin: 0;
    border-radius: 5px;
    overflow: hidden;
    display: flex;
    position: relative;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .slide-inner img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/5;
    object-fit: cover;
  }

  .slide-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none; 
  }

  .carousel-slide:hover .slide-overlay {
    opacity: 1;
  }

  .overlay-icon {
    width: 45px;
    height: 45px;
    fill: #FFFFFF;
    transform: translateY(15px);
    transition: transform 0.3s ease;
  }

  .carousel-slide:hover .overlay-icon {
    transform: translateY(0);
  }

  /* --- Setas de Navegação --- */
  .carousel-arrow {
    position: absolute;
    top: 45%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 10;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
  }

  .carousel-arrow:hover {
    opacity: 0.7;
  }

  .carousel-arrow.prev { left: 10px; }
  .carousel-arrow.next { right: 10px; }

  .carousel-arrow svg {
    width: 40px;
    height: 40px;
    fill: #FFFFFF;
    filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.4));
  }

  /* --- Paginação (Dots) --- */
  .carousel-pagination {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 40px;
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #0B4491; 
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .dot.active {
    opacity: 1;
    transform: scale(1.2);
  }

  /* Lógica de ocultação dos dots excedentes baseada em 6 itens */
  @media (min-width: 1025px) {
    /* Exibe 3 itens por vez, então precisamos apenas de 4 dots (0, 1, 2, 3) */
    .dot:nth-child(n+5) {
      display: none;
    }
  }

  @media (min-width: 768px) and (max-width: 1024px) {
    /* Exibe 2 itens por vez, então precisamos de 5 dots */
    .dot:nth-child(n+6) {
      display: none;
    }
  }

  /* --- Botões --- */
  .action-buttons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 30px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: filter 0.3s ease;
  }
  
  .btn:hover { filter: brightness(1.2); }

  .btn-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
  }

  /* Botão WhatsApp */
  .btn-whatsapp {
    background-image: url('https://samuelalcantara.com.br/wp-content/uploads/2025/02/bg-botao.webp');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    padding: 31px 40px 32px 85px;
    font-family: "DM Serif Text", serif;
    font-size: 20px;
    font-weight: 400;
    color: #F9F2EC;
    fill: #F9F2EC;
  }

  .btn-whatsapp svg { width: 20px; height: 20px; }

  /* Botão Instagram */
  .btn-instagram {
    background-color: #0B4491;
    border-radius: 5px;
    padding: 8px 13px;
    font-family: "Average Sans", sans-serif;
    font-size: 1.35em;
    font-weight: 400;
    color: #F9F2EC;
    fill: #F9F2EC;
  }

  .btn-instagram:hover { background-color: #0B4491D6; }
  .btn-instagram svg { width: 20px; height: 20px; }

  /* --- Animação de Dica (Hint) --- */
  @keyframes elementorHint {
    0% { transform: translate3d(0, 0, 0); }
    50% { transform: translate3d(-50%, 0, 0); }
    100% { transform: translate3d(0, 0, 0); }
  }

  .animate-hint .carousel-slide {
    animation: elementorHint 2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* --- Responsividade --- */
  @media (max-width: 1024px) {
    .section-header h2 { font-size: 38px; }
    .carousel-slide {
      flex: 0 0 calc(50% - 15px);
    }
  }

  @media (max-width: 767px) {
    .btn-instagram {
      padding: 8px 13px;
      font-size: 16px;
      font-weight: 400;
    }
    .carousel-track {
      gap: 0px;
      margin-bottom: -20px;
    }
    .instagram-section { padding: 60px 0px; }
    .section-header h2 { font-size: 32px; padding: 0px 15px; }
    .section-header p { font-size: 16px; padding: 15px 15px; }
    
    .carousel-slide { flex: 0 0 100%; }
    
    .carousel-arrow svg { width: 25px; height: 25px; }

    .action-buttons {
      flex-direction: column;
      gap: 10px;
      padding: 0 0 0 0;
    }
    
    .btn-whatsapp {
      padding: 40px 0px 40px 40px;
      width: 70%;
      font-size: 16px;
    }
  }
</style>

<script is:inline>
  function initInstagramCarousel() {
    const track = document.querySelector('#instagram-carousel .carousel-track');
    const prevBtn = document.querySelector('#instagram-carousel .carousel-arrow.prev');
    const nextBtn = document.querySelector('#instagram-carousel .carousel-arrow.next');
    const dots = document.querySelectorAll('.instagram-section .dot');
    
    if (!track) return;

    // Calcula a largura atual de um slide + gap
    const getSlideWidth = () => {
      const slide = track.querySelector('.carousel-slide');
      return slide ? slide.offsetWidth + 30 : 0; // 30px é o gap definido no CSS
    };

    // --- Navegação pelas Setas ---
    if (prevBtn) {
      prevBtn.onclick = () => {
        track.scrollBy({ left: -getSlideWidth(), behavior: 'smooth' });
      };
    }

    if (nextBtn) {
      nextBtn.onclick = () => {
        track.scrollBy({ left: getSlideWidth(), behavior: 'smooth' });
      };
    }

    // --- Lógica de clique nos Dots ---
    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        const targetElement = e.target;
        const targetIndex = parseInt(targetElement.getAttribute('data-target') || '0');
        track.scrollTo({ left: targetIndex * getSlideWidth(), behavior: 'smooth' });
      });
    });

    // --- Atualização de Dots com o Scroll ---
    track.addEventListener('scroll', () => {
      const scrollPosition = track.scrollLeft;
      const slideWidth = getSlideWidth();
      
      if (slideWidth === 0) return; 

      const slidesPerView = Math.round(track.clientWidth / slideWidth);
      const maxIndex = dots.length - slidesPerView;
      let currentIndex = Math.round(scrollPosition / slideWidth);
      
      if (currentIndex > maxIndex) {
          currentIndex = maxIndex;
      }

      dots.forEach((dot, index) => {
        if (index === currentIndex) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    }, { passive: true });

    // --- Arrasto com o mouse no Desktop (Drag to Scroll) ---
    let isDown = false;
    let startX;
    let scrollLeft;

    track.addEventListener('mousedown', (e) => {
      isDown = true;
      track.style.scrollSnapType = 'none'; // Desativa o snap durante o arrasto
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
      track.style.cursor = 'grabbing';
      
      // Previne que as imagens sejam "arrastadas" nativamente pelo navegador, quebrando a interação
      e.preventDefault(); 
    });

    track.addEventListener('mouseleave', () => {
      if(!isDown) return;
      isDown = false;
      track.style.scrollSnapType = 'x mandatory';
      track.style.cursor = 'auto';
    });

    track.addEventListener('mouseup', () => {
      if(!isDown) return;
      isDown = false;
      track.style.scrollSnapType = 'x mandatory';
      track.style.cursor = 'auto';
      // Força um pequeno scroll para ativar o snap após soltar
      track.scrollBy({ left: 1, behavior: 'smooth' });
    });

    track.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5; // Multiplicador para a velocidade do arrasto
      track.scrollLeft = scrollLeft - walk;
    });

    // --- Animação Hint via IntersectionObserver ---
    let animationExecuted = false; 
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (animationExecuted) return; 
        
        if (entry.isIntersecting) {
          animationExecuted = true; 
          
          entry.target.classList.add('animate-hint');
          
          setTimeout(() => {
            entry.target.classList.remove('animate-hint');
          }, 2500); 
          
          observer.disconnect(); 
        }
      });
    }, { threshold: 0.6 });

    observer.observe(track);
  }

  // Executa o script
  initInstagramCarousel();
  document.addEventListener('astro:page-load', initInstagramCarousel);
</script>