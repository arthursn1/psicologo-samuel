<style>
  :root {
    --color-primary: #0B4491;
    --color-primary-hover: #235BB2;
    --color-accent: #DC4C86;
    --color-accent-hover: #E86498;
    --font-heading: 'DM Serif Text', serif;
    --font-text: 'Open Sans', sans-serif;
  }

  /* --- Keyframes do Elementor replicados --- */
  @keyframes fadeInLeft {
    from { opacity: 0; transform: translate3d(-100%, 0, 0); }
    to { opacity: 1; transform: none; }
  }
  @keyframes fadeInDown {
    from { opacity: 0; transform: translate3d(0, -100%, 0); }
    to { opacity: 1; transform: none; }
  }
  @keyframes fadeInRight {
    from { opacity: 0; transform: translate3d(100%, 0, 0); }
    to { opacity: 1; transform: none; }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translate3d(0, 100%, 0); }
    to { opacity: 1; transform: none; }
  }

  /* Classes de controle de animação no Scroll */
  .animate-hidden {
    opacity: 0;
    visibility: hidden;
  }

  .animated {
    visibility: visible;
    animation-duration: 1.25s; /* Duração clássica do Elementor */
    animation-fill-mode: both;
  }

  .fadeInLeft { animation-name: fadeInLeft; }
  .fadeInDown { animation-name: fadeInDown; }
  .fadeInRight { animation-name: fadeInRight; }
  .fadeIn { animation-name: fadeIn; }
  .fadeInUp { animation-name: fadeInUp; }


  /* --- Estilos da Seção (Sem alterações) --- */
  .pain-points-section {
    padding: 90px 20px 170px;
    background-color: #ffffff;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: 40px;
