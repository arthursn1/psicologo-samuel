    transition: transform 0.2s;
  }
  .dialog-close:hover { transform: scale(1.2); }

  .modal-subtitle { font-family: var(--font-heading); font-size: 18px; font-weight: 500; color: var(--color-primary); margin: 0 0 10px 0; }
  .modal-title { font-family: var(--font-heading); font-size: 32px; font-weight: 400; line-height: 1.2em; color: var(--color-primary); margin: 0 0 15px 0; }
  .modal-text { font-family: var(--font-text); font-size: 16px; font-weight: 400; line-height: 1.5em; color: var(--color-primary); margin: 0 0 25px 0; }

.modal-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    text-decoration: none; font-family: var(--font-heading); font-size: 16px; font-weight: 400; color: #ffffff; fill: #ffffff;
    /* Ajuste aqui: 25px (cima), 75px (direita), 25px (baixo), 45px (esquerda) */
    padding: 25px 45px 25px 75px; 
    background-image: url('../../assets/bg-botao.webp');
    background-size: contain; background-repeat: no-repeat; background-position: center; background-color: transparent; transition: filter 0.3s ease;
  }
  .modal-btn:hover { filter: brightness(1.2); }
  .icon-whatsapp { width: 1.2em; height: 1.2em; }

  @media (max-width: 1024px) { .dialog-content { padding: 50px; } }
  @media (max-width: 767px) {
    .cards-grid { 
      margin-top: 50px;
      grid-template-columns: 1fr; 
      gap: 1px; /* Espacinho sutil entre um e outro no celular */
    }
    .card-text { font-size: 16px; }
    .pain-points-section { padding: 0 20px 60px; text-wrap: balance; }
    .section-title { font-size: 1.8em; padding: 0; margin: 30px 0 15px 0; }
    .dialog-content { padding: 30px; }
    .modal-subtitle { font-size: 14px; }
    .modal-title { font-size: 24px; }
    .modal-text { font-size: 15px; }
    .modal-btn { padding: 20px 30px 20px 0; font-size: 14px; width: 100%; background-size: contain; background-position: left; }
    .pain-card:nth-child(odd).animated {
      animation-name: fadeInLeft !important;
    }
    .pain-card:nth-child(even).animated {
      animation-name: fadeInRight !important;
    }
  }
</style>

<script>
  // Script para lidar com os Popups
  const triggers = document.querySelectorAll('[data-popup-trigger]');
  const closeBtns = document.querySelectorAll('[data-popup-close]');
  
  triggers.forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-popup-trigger');
      const dialog = document.getElementById(`dialog-${id}`) as HTMLDialogElement;
      if (dialog) dialog.showModal();
    });
  });

  closeBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-popup-close');
      const dialog = document.getElementById(`dialog-${id}`) as HTMLDialogElement;
      if (dialog) dialog.close();
    });
  });

  const dialogs = document.querySelectorAll('dialog');
  dialogs.forEach(dialog => {
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) {
        dialog.close();
      }
    });
  });

  // Script para disparar as animações ao rolar a página (Intersection Observer)
  const animateObserver = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target;
        // Pega qual animação deve rodar
        const animClass = el.getAttribute('data-animation');
        // Remove a classe que esconde e aplica as classes de animação
        el.classList.remove('animate-hidden');
        if (animClass) {
          el.classList.add('animated', animClass);
        }
        // Para de observar depois que animou a primeira vez
        observer.unobserve(el);
      }
    });
  }, {
    threshold: 0.1 // Dispara quando 10% do card aparecer na tela
  });

  document.querySelectorAll('.pain-card').forEach(card => {
    animateObserver.observe(card);
  });
</script>