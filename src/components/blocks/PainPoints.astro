  .pain-card.bg-pink { background-color: var(--color-accent); }
  .pain-card.bg-pink:hover { background-color: var(--color-accent-hover); }

  .pain-card.bg-blue { background-color: var(--color-primary); }
  .pain-card.bg-blue:hover { background-color: var(--color-primary-hover); }

  .card-icon { margin-bottom: 15px; }

  .pain-card:hover .card-icon {
    animation: bob 1s infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .card-text {
    font-family: var(--font-text);
    font-size: 20px;
    font-weight: 600;
    line-height: 1.2em;
    margin: 0;
  }

  /* --- Popups Dialogs (Sem alterações) --- */
  .pain-dialog {
    border: none;
    background: transparent;
    padding: 0;
    margin: auto;
    overflow: visible;
    max-width: 90vw;
  }

  .pain-dialog::backdrop { background-color: rgba(0, 0, 0, 0.8); }

  .dialog-content {
    background-image: linear-gradient(180deg, #F9C5CC 5%, #FACFD6 25%);
    width: 635px;
    max-width: 100%;
    position: relative;
    border-radius: 3px;
    clip-path: polygon(0% 0%, 0.5% 20%, 0 100%, 80% 98.7%, 90% 98.7%, 100% 98.9%, 99.9% 90%, 99% 0%);
    padding: 60px 85px 60px 50px;
    transform: rotate(-0.4deg);
    animation: colaPostIt 0.8s cubic-bezier(0.25, 0.46, 0.45, 1.2) forwards;
    transform-origin: left center;
  }

  @keyframes colaPostIt {
    0% { transform: translateX(-100%) rotate(-15deg) scale(0.8); opacity: 0; }
    70% { transform: translateX(5%) rotate(-8deg) scale(1.02); opacity: 0.9; }
    100% { transform: translateX(0) rotate(-0.4deg) scale(1); opacity: 1; }
  }

  .dialog-inner {
    transform: rotate(-0.02deg);
    position: relative;
    animation: aparecerSuave 0.5s ease-out 0.3s both;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  @keyframes aparecerSuave {
    from { opacity: 0; transform: translateY(20px) rotate(-0.02deg); }
    to { opacity: 1; transform: translateY(0) rotate(-0.02deg); }
  }

  .dialog-close {
    position: absolute;
    top: 20px;
    right: 25px;
