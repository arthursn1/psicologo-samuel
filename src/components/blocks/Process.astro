---

<section class="process-section">
  <div class="container">
    
    <header class="section-header">
      <h2><span class="dest4">Como funciona</span> o processo?</h2>
    </header>

    <div class="timeline-wrapper">
      <Image src={LinhaGrande} class="timeline-line" alt="Linha do tempo" loading="lazy" decoding="async" />

      {steps.map((step) => (
        <div class={`timeline-item ${step.align} ${step.pinClass}`} style={`width: ${step.width};`}>
          <div class="timeline-icon" set:html={step.icon} />
          
          <div class="timeline-content">
            <h3>{step.title}</h3>
            <p set:html={step.desc}></p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* --- Seção Base --- */
  .process-section {
    background-color: #0B4491;
    background-image: url('../../assets/Prancheta-Final.png');
    background-position: bottom center;
    background-repeat: no-repeat;
    background-size: contain;
    padding: 90px 20px 160px;
    position: relative;
    overflow: hidden;
  }

  .container {
    max-width: 1140px;
    margin: 0 auto;
    position: relative;
  }

  /* --- Cabeçalho e Destaque --- */
  .section-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .section-header h2 {
    font-family: "DM Serif Text", serif;
    font-size: 40px;
    font-weight: 400;
    line-height: 1.2em;
    color: #F9F2EC;
    margin: 0;
  }

  .dest4 {
    background: #E4709E;
    padding: 0px 4px;
    position: relative;
    display: inline-block;
    border-left: 1px solid #F9F2EC;
    border-right: 1px solid #F9F2EC;
    font-style: italic;
  }

  .dest4::before, 
  .dest4::after {
    content: "";
    position: absolute;
    background: #F9F2EC;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    z-index: 2;
  }

  .dest4::before { top: -3px; left: -4px; }
  .dest4::after { bottom: -3px; right: -4px; }

  /* --- Timeline Base --- */
  .timeline-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 80px;
    margin-top: 50px;
  }

  .timeline-line {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    height: 100%;
    width: auto;
    object-fit: contain;
    pointer-events: none;
    z-index: 0;
  }

  /* --- Itens (Cards) --- */
  .timeline-item {
    position: relative;
    background-color: #D94881;
    padding: 30px;
    z-index: 1;
  }

  .timeline-item.left {
    align-self: flex-start;
    text-align: left;
  }

  .timeline-item.right {
    align-self: flex-end;
    text-align: left; /* Modificado de right para left */
  }

  /* --- Alfinetes (Pins) --- */
  .timeline-item.card1::before {
    content: "";
    position: absolute;
    top: -55px;
    left: 0;
    background: url('../../assets/Blue-Pin-4.svg') center/contain no-repeat;
    width: 40px;
    height: 60px;
  }

  .timeline-item.card2::before {
    content: "";
    position: absolute;
    top: -55px;
    right: 0;
    left: auto;
    background: url('../../assets/Blue-Pin-5.svg') center/contain no-repeat;
    width: 40px;
    height: 60px;
  }

  /* --- Ícones --- */
  .timeline-icon {
    display: inline-block;
    margin-bottom: 10px;
  }

  .timeline-icon :global(svg) {
    width: 45px;
    height: 45px;
  }

  /* --- Conteúdo de Texto --- */
  .timeline-content h3 {
    font-family: "DM Serif Text", serif;
    font-size: 36px;
    font-weight: 400;
    line-height:1.4em;
    color: #F9F2EC;
    margin: 0 0 10px 0;
  }

  .timeline-content p {
    font-family: "Open Sans", sans-serif;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.5em;
    color: #FFFFFF;
    margin: 0;
  }

  /* --- Responsividade --- */
  @media (max-width: 1024px) {
    .timeline-item {
      width: 70% !important;
    }
    .timeline-wrapper {
      gap: 60px;
    }
  }

  @media (max-width: 767px) {
    .process-section {
      padding: 60px 20px 90px;
    }
    
    .section-header h2 {
      font-size: 32px;
    }

    .timeline-content h3 {
      font-size: 26px;
      line-height:1.3em;
    }

    .timeline-content p {
      font-size: 14px;
      line-height: 1.5em;
    }

    .timeline-wrapper {
      gap: 30px;
    }

    .timeline-line {
      display: none; 
    }

    .timeline-item {
      width: 100% !important;
      align-self: center !important;
      text-align: left !important;
    }

    .timeline-item::before {
      display: none;
    }
  }
</style>